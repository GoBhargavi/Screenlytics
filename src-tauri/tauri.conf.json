{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "© 2024 Screenlytics",
    "targets": ["app", "dmg", "msi", "deb", "appimage"],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "AI-powered workforce focus intelligence platform",
    "shortDescription": "Focus intelligence for teams",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": null
    }
  },
  "productName": "Screenlytics Enterprise",
  "mainBinaryName": "Screenlytics Enterprise",
  "version": "1.0.0",
  "identifier": "com.screenlytics.enterprise",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "minHeight": 700,
        "resizable": true,
        "title": "Screenlytics Enterprise",
        "width": 1400,
        "minWidth": 1200,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false,
      " dangerousUseIframeSandbox": false,
      "dangerousRemoteDomainIpcAccess": [],
      "iframe_parents": [],
      "pattern": {
        "use": "brownfield"
      }
    }
  }
}
